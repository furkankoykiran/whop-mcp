{
  "name": "whop-mcp",
  "version": "1.0.3",
  "description": "Community-led MCP server for Whop.com Company API — manage payments, memberships, products, promo codes, and more via AI.",
  "author": "Community Contributors",
  "license": "MIT",
  "keywords": [
    "mcp",
    "whop",
    "model-context-protocol",
    "ai",
    "claude",
    "cursor",
    "typescript"
  ],
  "homepage": "https://github.com/furkankoykiran/whop-mcp#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/furkankoykiran/whop-mcp.git"
  },
